# ─────────────────────────────────────────────────────────────────
#  SDLC Automation Copilot — Environment Configuration
#  Copy this file to `.env` and fill in your credentials.
# ─────────────────────────────────────────────────────────────────

# ── LLM: Groq Cloud ─────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── HuggingFace Hub ─────────────────────────────────────────────
# Get this from: https://huggingface.co/settings/tokens
# Use READ token for downloading models (sufficient for embeddings)
HF_TOKEN=hf_your_huggingface_token_here

# ── Relational Database: PostgreSQL ─────────────────────────────
# Get this from: Render (render.com), Neon (neon.tech), or Supabase
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql://jwt_sdlc_auth_user:RimkgmYmu5DPGD8RDMSB8tltRisufTKm@dpg-d7fkh7pf9bms73eiodog-a.oregon-postgres.render.com/jwt_sdlc_auth

# ── Vector Search: Pinecone ──────────────────────────────────────
# Get this from: https://app.pinecone.io
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=sdlc-copilot

# ── Document Store: Qdrant Cloud ─────────────────────────────────
# Get this from: https://cloud.qdrant.io (free tier available)
QDRANT_URL=https://your-cluster-id.us-east4-0.gcp.cloud.qdrant.io:6333
QDRANT_API_KEY=your_qdrant_api_key_here
QDRANT_COLLECTION_NAME=sdlc_documents

# ── App Settings ─────────────────────────────────────────────────
ENVIRONMENT=production

# ── JWT Authentication ───────────────────────────────────────────
# Generate a secure random key: openssl rand -hex 32
JWT_SECRET_KEY=your_jwt_secret_key_here_replace_with_random_string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
